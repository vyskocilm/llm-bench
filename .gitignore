# Model weights (large; reproduce via pull-model.sh + MODELS.md)
models/
*.gguf

# Built llama.cpp + source tree (rebuild via build.sh)
dist/
llama.cpp/

# Bench transient artifacts
bench/deep/smoke/
bench/deep/__pycache__/
