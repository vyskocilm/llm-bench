bench/**/*.log
bench/*.log

# Build logs from the local one-shot build
build.log
podman-build.log

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
*.tmp

# Haiku-experiment artifacts (FYI, not for public bench)
bench/haiku/
bench/haiku-core/
bench/haiku-*/
